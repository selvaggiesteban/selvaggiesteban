---
import Button from './Button.astro';
import { getLocaleFromUrl, t } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const lang = locale as 'es' | 'en';
const privacyHref = locale === 'es' ? '/es/privacy-policy' : '/en/privacy-policy';
---

<div class="mt-xl pt-xl border-t border-hairline">
  <div class="max-w-4xl mx-auto text-center flex flex-col items-center">
    <h2 class="display-sm mb-4">{t(lang, 'contact.heading')}</h2>
    <p class="mb-12 text-ink/70 max-w-2xl text-center">
      {t(lang, 'contact.subtitle')}
    </p>

    <form id="contact-form" class="w-full space-y-6 bg-canvas p-8 md:p-12 rounded-[9px] border border-hairline shadow-sm text-left">
      <div class="space-y-2">
        <label for="name" class="font-mono text-xs uppercase tracking-widest text-ink/40">{t(lang, 'contact.nombre')}</label>
        <input type="text" id="name" name="name" required class="w-full p-4 bg-surface-soft border border-hairline rounded-[9px] focus:border-primary outline-none transition-colors" />
      </div>

      <div class="space-y-2">
        <label for="email" class="font-mono text-xs uppercase tracking-widest text-ink/40">{t(lang, 'contact.email')}</label>
        <input type="email" id="email" name="email" required class="w-full p-4 bg-surface-soft border border-hairline rounded-[9px] focus:border-primary outline-none transition-colors" />
      </div>

      <div class="space-y-2">
        <label for="message" class="font-mono text-xs uppercase tracking-widest text-ink/40">{t(lang, 'contact.mensaje')}</label>
        <textarea id="message" name="message" rows="4" required class="w-full p-4 bg-surface-soft border border-hairline rounded-[9px] focus:border-primary outline-none transition-colors"></textarea>
      </div>

      <div class="flex items-start gap-2 pt-2">
        <input type="checkbox" id="privacy" name="privacy" required class="mt-1 accent-primary focus:ring-primary w-4 h-4" />
        <label for="privacy" class="text-sm text-ink/70">
          {t(lang, 'contact.privacyPrefix')} <a href={privacyHref} class="text-primary underline hover:text-primary-dark" target="_blank">{t(lang, 'contact.privacyLink')}</a> {t(lang, 'contact.privacySuffix')}
        </label>
      </div>

      <div id="my-turnstile-container" class="min-h-[65px] flex justify-center mb-4"></div>

      <Button type="submit" class="w-full text-lg py-4">{t(lang, 'contact.submit')}</Button>

      <p id="form-status" class="text-sm mt-4 hidden"></p>
    </form>
  </div>
</div>

<script>
  const initTurnstile = () => {
    const container = document.getElementById('my-turnstile-container');
    if (!container || container.innerHTML.trim() !== '') return;

    const script = document.createElement('script');
    script.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit';
    script.async = true;
    script.defer = true;

    script.onload = () => {
      if (window.turnstile) {
        window.turnstile.render('#my-turnstile-container', {
          sitekey: '0x4AAAAAADfmwu_oZrA1JtFm',
          theme: 'light'
        });
      }
    };

    document.head.appendChild(script);
  };

  document.addEventListener('DOMContentLoaded', initTurnstile);
  document.addEventListener('astro:page-load', initTurnstile);
  initTurnstile();

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    if (!data['cf-turnstile-response']) {
      status.textContent = 'Please wait for the security captcha to complete.';
      status.classList.remove('hidden', 'text-semantic-success', 'text-ink/60');
      status.classList.add('text-red-500');
      return;
    }

    status.textContent = 'Sending...';
    status.classList.remove('hidden', 'text-semantic-success', 'text-red-500');
    status.classList.add('text-ink/60');

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        body: JSON.stringify(data),
        headers: {
          'Content-Type': 'application/json'
        }
      });

      if (response.ok) {
        form.reset();
        if (window.turnstile) window.turnstile.reset();
        const thankYouHref = window.location.pathname.startsWith('/en') ? '/en/contact/thank-you' : '/es/contact/thank-you';
        window.location.href = thankYouHref;
      } else {
        const error = await response.json();
        status.textContent = `Error: ${error.message || 'Could not send message.'}`;
        status.classList.add('text-red-500');
      }
    } catch (e) {
      status.textContent = 'Connection error. Please try again.';
      status.classList.add('text-red-500');
    }
  });
</script>