---
import Container from './Container.astro';
import { getLocaleFromUrl, t } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const lang = locale as 'es' | 'en';
const year = new Date().getFullYear();
const isCV = Astro.url.pathname.includes('/cv/');

const p = (path: string) => locale === 'es' ? `/es${path}` : `/en${path}`;
const serviceLink = (esSlug: string, enSlug: string) => locale === 'es' ? `/es/services/${esSlug}` : `/en/services/${enSlug}`;
const cvLink = (esSlug: string, enSlug: string) => locale === 'es' ? `/es/cv/${esSlug}` : `/en/cv/${enSlug}`;
const blogLink = (esSlug: string, enSlug: string) => locale === 'es' ? `/es/blog/${esSlug}` : `/en/blog/${enSlug}`;
---

<footer class="bg-canvas border-t border-hairline pt-section pb-8 mt-section">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-xl mb-xl">      
      <div class="lg:col-span-2">
        <a href={p('/')} class="text-2xl font-bold tracking-tighter">selvaggiesteban.dev</a>
        <p class="mt-4 text-sm text-ink/60 mb-6 leading-relaxed">
          {t(lang, 'footer.bio')}
        </p>
        <ul class="space-y-3 text-sm text-ink/80 mb-8">
          <li><a href={cvLink('ingeniero-en-informatica', 'computer-science-engineer')} class="hover:underline text-primary">{t(lang, 'footer.ingenieroInformatica')}</a></li>
          <li><a href={cvLink('ingeniero-en-software', 'software-engineer')} class="hover:underline text-primary">{t(lang, 'footer.ingenieroSoftware')}</a></li>
          <li><a href={cvLink('desarrollador-web-full-stack', 'full-stack-web-developer')} class="hover:underline text-primary">{t(lang, 'footer.desarrolladorFullStack')}</a></li>
          <li><a href={cvLink('experto-en-posicionamiento-seo', 'seo-positioning-specialist')} class="hover:underline text-primary">{t(lang, 'footer.expertoSEO')}</a></li>
        </ul>
        <h4 class="font-mono text-xs uppercase tracking-widest text-ink/40 mb-4">{t(lang, 'footer.contacto')}</h4>
        <ul class="space-y-2 text-sm text-ink/80 flex flex-col">
          <li>{t(lang, 'footer.email')} <a href="mailto:selvaggiesteban@gmail.com" class="hover:underline text-primary">selvaggiesteban@gmail.com</a></li>
          <li>{t(lang, 'footer.telefono')} <a href="tel:+5491153323937" class="hover:underline text-primary">(+54) 9 11 5332-3937</a></li>
        </ul>
      </div>

      {!isCV && (
        <div>
          <h4 class="font-mono text-xs uppercase tracking-widest text-ink/40 mb-6">{t(lang, 'footer.servicios')}</h4>
          <ul class="space-y-3 text-sm text-ink/80">
            <li><a href={serviceLink('software-a-medida', 'custom-software')} class="hover:underline hover:text-primary transition-colors">{t(lang, 'services.softwareAMedida')}</a></li>
            <li><a href={serviceLink('diseno-web-responsive', 'responsive-web-design')} class="hover:underline hover:text-primary transition-colors">{t(lang, 'services.disenoWeb')}</a></li>
            <li><a href={serviceLink('posicionamiento-seo', 'seo-positioning')} class="hover:underline hover:text-primary transition-colors">{t(lang, 'services.seo')}</a></li>
            <li><a href={serviceLink('posicionamiento-sem', 'sem-positioning')} class="hover:underline hover:text-primary transition-colors">{t(lang, 'services.sem')}</a></li>
            <li><a href={serviceLink('e-mail-marketing', 'e-mail-marketing')} class="hover:underline hover:text-primary transition-colors">{t(lang, 'services.emailMarketing')}</a></li>
          </ul>
        </div>
      )}

      {!isCV && (
        <div>
          <h4 class="font-mono text-xs uppercase tracking-widest text-ink/40 mb-6">{t(lang, 'footer.guiasSEO')}</h4>
          <ul class="space-y-3 text-sm text-ink/80 flex flex-col">
            <li><a href={blogLink('seo-local-guia-completa-para-dominar-la-busqueda-local', 'local-seo-complete-guide-to-mastering-local-search')} class="hover:underline hover:text-primary transition-colors line-clamp-1">SEO Local</a></li>
            <li><a href={blogLink('seo-on-page-la-guia-definitiva-para-dominar-tu-web', 'on-page-seo-the-ultimate-guide-to-mastering-your-website')} class="hover:underline hover:text-primary transition-colors line-clamp-1">SEO On-Page</a></li>
            <li><a href={blogLink('seo-off-page-la-guia-definitiva-para-dominar-el-posicionamiento', 'off-page-seo-the-ultimate-guide-to-mastering-external-positioning')} class="hover:underline hover:text-primary transition-colors line-clamp-1">SEO Off-Page</a></li>
            <li><a href={blogLink('seo-de-contenidos-guia-completa-para-dominar-el-ranking', 'content-seo-complete-guide-to-mastering-the-rankings')} class="hover:underline hover:text-primary transition-colors line-clamp-1">SEO de Contenidos</a></li>
            <li><a href={blogLink('consultoria-seo-guia-definitiva-para-el-exito-digital', 'seo-consulting-the-ultimate-guide-to-digital-success')} class="hover:underline hover:text-primary transition-colors line-clamp-1">Consultoría SEO</a></li>
            <li><a href={blogLink('seo-local-la-guia-definitiva-para-atraer-clientes-cercanos', 'local-seo-the-ultimate-guide-to-attracting-nearby-customers')} class="hover:underline hover:text-primary transition-colors line-clamp-1">SEO Local Avanzado</a></li>
            <li><a href={blogLink('mantenimiento-web-la-guia-definitiva-para-un-sitio-seguro-y-optimizado', 'web-maintenance-the-ultimate-guide-to-a-secure-and-optimized-website')} class="hover:underline hover:text-primary transition-colors line-clamp-1">Mantenimiento Web</a></li>
            <li><a href={blogLink('las-mejores-herramientas-de-marketing-digital-para-2024', 'the-best-digital-marketing-tools-for-2024')} class="hover:underline hover:text-primary transition-colors line-clamp-1">Herramientas Marketing Digital</a></li>
            <li><a href={blogLink('analitica-web-guia-completa-para-dominar-tus-datos-online', 'web-analytics-complete-guide-to-mastering-your-online-data')} class="hover:underline hover:text-primary transition-colors line-clamp-1">Analítica Web</a></li>
          </ul>
        </div>
      )}

      {!isCV && (
        <div>
          <h4 class="font-mono text-xs uppercase tracking-widest text-ink/40 mb-6">{t(lang, 'footer.desarrolloIA')}</h4>
          <ul class="space-y-3 text-sm text-ink/80 flex flex-col">
            <li><a href={blogLink('actualizaciones-web', 'website-updates')} class="hover:underline hover:text-primary transition-colors line-clamp-1">Actualizaciones Web</a></li>
            <li><a href={blogLink('landing-page', 'landing-page')} class="hover:underline hover:text-primary transition-colors line-clamp-1">Landing Pages Optimizadas</a></li>
            <li><a href={blogLink('experto-wordpress-tu-guia-definitiva-para-el-exito-digital', 'wordpress-expert-your-ultimate-guide-to-digital-success')} class="hover:underline hover:text-primary transition-colors line-clamp-1">Experto WordPress</a></li>
            <li><a href={blogLink('sistema-multi-agente-con-ia', 'ai-multi-agent-system')} class="hover:underline hover:text-primary transition-colors line-clamp-1">Sistemas Multi-Agente con IA</a></li>
            <li><a href={blogLink('ejercito-de-juniors', 'army-of-juniors')} class="hover:underline hover:text-primary transition-colors line-clamp-1">Ejército de Juniors</a></li>
            <li><a href={blogLink('claude-code-gratis', 'free-claude-code')} class="hover:underline hover:text-primary transition-colors line-clamp-1">Claude Code Gratis</a></li>
            <li><a href={blogLink('prompts-para-ia', 'ai-prompts')} class="hover:underline hover:text-primary transition-colors line-clamp-1">Prompts para IA</a></li>
            <li><a href={blogLink('automatizacion-de-marketing-profesional', 'professional-marketing-automation')} class="hover:underline hover:text-primary transition-colors line-clamp-1">Automatización de Marketing</a></li>
            <li><a href={blogLink('experto-en-automatizacion-rpa', 'rpa-automation-expert')} class="hover:underline hover:text-primary transition-colors line-clamp-1">Experto en Automatización RPA</a></li>
          </ul>
        </div>
      )}
    </div>

    <div class="pt-8 border-t border-hairline flex flex-col md:flex-row justify-between items-center text-xs text-ink/40 uppercase tracking-widest font-mono gap-4 md:gap-0">     
      <span>© {year} Esteban Selvaggi</span>
      <div class="flex gap-6">
        <a href={p('/privacy-policy')} class="hover:text-primary transition-colors">{t(lang, 'footer.privacidad')}</a>
        <a href={p('/cookie-policy')} class="hover:text-primary transition-colors">{t(lang, 'footer.cookies')}</a>
      </div>
    </div>
  </Container>
</footer>