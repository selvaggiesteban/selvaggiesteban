---
import { getCollection } from 'astro:content';
import Section from './Section.astro';

const allPosts = await getCollection('blog');
const recommendedPosts = allPosts.sort((a, b) => {
  const dateA = a.data.pubDate ? new Date(a.data.pubDate).valueOf() : 0;
  const dateB = b.data.pubDate ? new Date(b.data.pubDate).valueOf() : 0;
  return dateB - dateA;
});

// Duplicamos el array para lograr el efecto continuo de "marquee" en CSS puro
const extendedPosts = [...recommendedPosts, ...recommendedPosts];
---

<Section variant="white" id="recommended" class="reveal !py-12 overflow-hidden" fullWidth={true}>
  <div class="px-lg md:px-xxl mb-12">
    <h2 class="display-lg mb-2">Recomendado para usted</h2>
    <div class="w-20 h-1 bg-primary mb-8"></div>
  </div>

  <div class="relative w-full overflow-hidden flex flex-col group">
    <!-- Mask gradients for smooth edges -->
    <div class="absolute left-0 top-0 bottom-0 w-16 md:w-32 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-16 md:w-32 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>

    <div class="flex w-max animate-marquee">
      {extendedPosts.map((post) => (
        <a href={`/blog/${post.id}`} class="w-[300px] md:w-[400px] mx-3 flex-shrink-0 flex flex-col bg-[#f9f9f9] rounded-[9px] border border-hairline overflow-hidden shadow-sm hover:shadow-md transition-all duration-300">
          <div class="aspect-video overflow-hidden bg-surface-soft relative">
            <span class="absolute top-4 left-4 z-10 bg-primary text-white text-[10px] font-bold px-2 py-1 uppercase tracking-widest rounded-[2px]">
              Artículo
            </span>
            <div class="w-full h-full flex items-center justify-center text-ink/20 font-mono text-[10px] uppercase tracking-widest bg-gradient-to-br from-surface-soft to-gray-100">
               Lectura recomendada
            </div>
          </div>

          <div class="p-6 flex flex-col flex-grow">
            <h3 class="text-lg font-bold mb-3 group-hover:text-primary transition-colors line-clamp-2 leading-tight">
              {post.data.title}
            </h3>
            <p class="text-xs text-ink/60 line-clamp-3 mb-6 flex-grow">
              {post.data.description}
            </p>
            <div class="flex items-center text-[10px] font-bold uppercase tracking-widest text-primary">
              Leer más <span class="ml-1">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Section>

<style>
  @keyframes marquee {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .animate-marquee {
    animation: marquee 120s linear infinite;
    animation-play-state: paused;
  }

  .animate-marquee:hover {
    animation-play-state: running;
  }

  @media (max-width: 768px) {
    .animate-marquee {
      animation-duration: 60s;
    }
  }
</style>