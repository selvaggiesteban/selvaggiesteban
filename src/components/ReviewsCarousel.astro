    </button>
    <button id="next-review" class="absolute right-8 top-1/2 -translate-y-1/2 z-30 bg-white/90 border border-hairline p-4 rounded-full shadow-lg opacity-0 group-hover:opacity-100 transition-opacity hover:bg-white active:scale-95" aria-label="Siguiente">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>

    <div id="review-track" class="flex gap-4 overflow-x-auto snap-x snap-mandatory scrollbar-hide py-4 px-lg md:px-xxl cursor-grab active:cursor-grabbing select-none" style="scroll-behavior: smooth;">
      {extendedReviews.map((review) => {
        const isLong = review.text.length > 130;
        const displayText = isLong ? review.text.substring(0, 130) + "..." : review.text + '"';
        return (
        <div class="w-[280px] lg:w-[calc(20%-1rem)] h-[300px] flex-shrink-0 bg-white p-5 rounded-3xl border border-gray-100 shadow-[0_10px_40px_-15px_rgba(0,0,0,0.05)] snap-center transition-transform duration-300 relative flex flex-col">
          <img src="/assets/skills/google-icon.svg" alt="Google Review" class="absolute top-5 right-5 w-4 h-4 opacity-80" />
          
          <div class="flex items-center gap-3 mb-4">
            <div class:list={["w-10 h-10 rounded-full overflow-hidden flex items-center justify-center font-bold text-base shadow-sm border border-gray-100", review.color]}>
              <img 
                src={`/assets/reviews/${review.name.toLowerCase().replace(/\s+/g, '-')}.webp`} 
                alt={review.name} 
                class="w-full h-full object-cover"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />
              <span class="hidden items-center justify-center w-full h-full text-white/90">
                {review.name.charAt(0)}
              </span>
            </div>
            <div>
              <span class="font-bold text-gray-900 block leading-tight text-sm">{review.name}</span>
              <div class="flex gap-0.5 mt-1">
                {[...Array(review.rating)].map((_, i) => (
                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="12" viewBox="0 0 24 24" fill="#fbbf24" stroke="#fbbf24" class="lucide lucide-star"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                ))}
              </div>
            </div>
          </div>
          <div class="flex-grow overflow-hidden relative">
            <p class="text-[13px] text-gray-600 leading-relaxed">
              "{displayText}
            </p>
            {isLong && (
              <a 
                href="https://share.google/1LpGxeLM3Wan7iCuY" 
                target="_blank" 
                rel="noopener noreferrer"
                class="text-[10px] font-bold text-primary mt-2 inline-block hover:underline"
              >
                Leer más en Google
