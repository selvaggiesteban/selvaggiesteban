---

<Section variant="white" id="reviews" class="overflow-hidden py-20 relative !py-12" fullWidth={true}>
  <div class="px-lg md:px-xxl mb-12 reveal">
    <h2 class="display-lg mb-4 text-center">Reseñas de clientes</h2>
    <p class="text-xl text-ink/60 mb-8 text-center max-w-2xl mx-auto">Lo que dicen quienes ya confían en mi ingeniería de excelencia.</p>
  </div>

  <div class="relative group">
    <!-- Botones de Navegación -->
    <button id="prev-review" class="absolute left-8 top-1/2 -translate-y-1/2 z-30 bg-white/90 border border-hairline p-4 rounded-full shadow-lg opacity-0 group-hover:opacity-100 transition-opacity hover:bg-white active:scale-95" aria-label="Anterior">
