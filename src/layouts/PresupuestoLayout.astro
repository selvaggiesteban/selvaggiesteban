---
import SEO from '../components/seo/SEO.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <!-- Bloquear indexación de presupuestos -->
    <meta name="robots" content="noindex, nofollow" />
    <SEO {title} {description} />
  </head>
  <body class="bg-surface">
    <!-- Header minimalista alineado al ancho global -->
    <header class="py-6 border-b border-hairline bg-white mb-8">
      <div class="max-w-7xl mx-auto px-lg md:px-xxl flex justify-between items-center">
        <a href="/" class="text-2xl font-bold tracking-tighter text-ink">selvaggiesteban.dev</a>
        <span class="text-sm font-mono text-ink/40 uppercase tracking-widest hidden sm:inline-block">Presupuesto Privado</span>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-lg md:px-xxl pb-20">
      <slot />
    </main>

    <!-- Footer minimalista -->
    <footer class="py-8 border-t border-hairline text-center">
      <p class="text-xs text-ink/40 font-mono uppercase tracking-widest">© {new Date().getFullYear()} SELVAGGI ESTEBAN - Documento Comercial</p>
    </footer>
  </body>
</html>