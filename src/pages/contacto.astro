---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';

const title = "Contacto";
const description = "Ponte en contacto con nosotros para discutir tu próximo proyecto web.";
---

<BaseLayout {title} {description}>
  <Section variant="white" class="reveal">
    <div class="max-w-4xl mx-auto text-center flex flex-col items-center">
      <h1 class="display-lg mb-md">Hablemos.</h1>
      <p class="mb-xl text-lg opacity-70 max-w-2xl text-center">
        ¿Tienes un proyecto en mente o simplemente quieres saludar? Completa el formulario y te responderé lo antes posible.
      </p>

      <form id="contact-form" class="w-full space-y-lg bg-canvas p-xl rounded-lg border border-hairline shadow-sm text-left">
        <div class="space-y-xs">
          <label for="name" class="font-mono text-xs uppercase tracking-widest text-ink/40">Nombre</label>
          <input type="text" id="name" name="name" required class="w-full p-md bg-surface-soft border border-hairline rounded-md focus:border-primary outline-none transition-colors" />
        </div>

        <div class="space-y-xs">
          <label for="email" class="font-mono text-xs uppercase tracking-widest text-ink/40">Email</label>
          <input type="email" id="email" name="email" required class="w-full p-md bg-surface-soft border border-hairline rounded-md focus:border-primary outline-none transition-colors" />
        </div>

        <div class="space-y-xs">
          <label for="message" class="font-mono text-xs uppercase tracking-widest text-ink/40">Mensaje</label>
          <textarea id="message" name="message" rows="4" required class="w-full p-md bg-surface-soft border border-hairline rounded-md focus:border-primary outline-none transition-colors"></textarea>
        </div>

        <div class="flex items-start gap-2 pt-2">
          <input type="checkbox" id="privacy" name="privacy" required class="mt-1 accent-primary focus:ring-primary w-4 h-4" />
          <label for="privacy" class="text-sm text-ink/70">
            He leído y acepto la política de privacidad y el tratamiento de mis datos personales.
          </label>
        </div>

        <!-- Cloudflare Turnstile -->
        <div id="my-turnstile-container" class="min-h-[65px] flex justify-center mb-4"></div>

        <Button type="submit" class="w-full">Enviar mensaje</Button>

        <p id="form-status" class="text-sm mt-md hidden"></p>
        </form>
        </div>
        </Section>

        <script>
        // Inyectamos el script dinámicamente y lo renderizamos de forma segura en Astro
        const initTurnstile = () => {
        const container = document.getElementById('my-turnstile-container');
        // Evitamos re-renderizar si ya existe
        if (!container || container.innerHTML.trim() !== '') return;

        const script = document.createElement('script');
        script.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit';
        script.async = true;
        script.defer = true;

        script.onload = () => {
        if (window.turnstile) {
          window.turnstile.render('#my-turnstile-container', {
            sitekey: '0x4AAAAAADfmwu_oZrA1JtFm',
            theme: 'light'
          });
        }
        };

        document.head.appendChild(script);
        };

        // Aseguramos carga inicial
        document.addEventListener('DOMContentLoaded', initTurnstile);
        // Aseguramos carga en navegaciones PWA/Astro
        document.addEventListener('astro:page-load', initTurnstile);
        // Disparo inmediato por si DOMContentLoaded ya pasó
        initTurnstile();

        const form = document.getElementById('contact-form') as HTMLFormElement;
        const status = document.getElementById('form-status');

        form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!status) return;

        const formData = new FormData(form);
        const data = Object.fromEntries(formData);

        if (!data['cf-turnstile-response']) {
        status.textContent = 'Por favor, espera a que el captcha de seguridad se complete.';
        status.classList.remove('hidden', 'text-semantic-success', 'text-ink/60');
        status.classList.add('text-red-500');
        return;
        }

        status.textContent = 'Enviando...';
        status.classList.remove('hidden', 'text-semantic-success', 'text-red-500');
        status.classList.add('text-ink/60');

        try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: JSON.stringify(data),
          headers: {
            'Content-Type': 'application/json'
          }
        });

        if (response.ok) {
          status.textContent = '¡Gracias! Tu mensaje ha sido enviado correctamente.';
          status.classList.add('text-semantic-success');
          form.reset();
          // Reset turnstile
          if (window.turnstile) {
            window.turnstile.reset();
          }
        } else {
          const error = await response.json();
          status.textContent = `Error: ${error.message || 'No se pudo enviar el mensaje.'}`;
          status.classList.add('text-red-500');
        }
        } catch (e) {
        status.textContent = 'Error de conexión. Inténtalo de nuevo.';
        status.classList.add('text-red-500');
        }
        });
        </script>
        </BaseLayout>
