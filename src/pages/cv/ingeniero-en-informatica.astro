---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Button from '../../components/Button.astro';

const title = "CV Ingeniero en Informática - Esteban Selvaggi";
const description = "Curriculum Vitae optimizado para ATS de Esteban Selvaggi, Ingeniero Informático experto en arquitectura de sistemas e ingeniería de software.";
---

<BaseLayout {title} {description} isProfile={true}>
  <Section variant="white" class="pt-24 pb-16 reveal">
    <div class="w-full mx-auto">
      
      <!-- Header: 2 columnas -->
      <div class="border-b border-hairline pb-8 mb-8 grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
        <!-- Columna izquierda: identidad -->
        <div>
          <h1 class="display-lg mb-1">Esteban Selvaggi</h1>
          <p class="text-2xl text-primary font-medium">Ingeniero en Informática</p>
        </div>

        <!-- Columna derecha: share + contacto -->
        <div class="flex flex-col gap-5 md:items-end">
          <!-- Íconos compartir -->
          <div class="flex gap-2">
            <button onclick="navigator.clipboard.writeText(window.location.href); alert('Enlace copiado al portapapeles');" class="p-2 bg-surface-soft border border-hairline rounded-full hover:bg-ink hover:text-white transition-colors text-ink cursor-pointer" title="Copiar Enlace">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            </button>
            <button onclick="window.print()" class="p-2 bg-surface-soft border border-hairline rounded-full hover:bg-ink hover:text-white transition-colors text-ink cursor-pointer" title="Imprimir CV">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
            </button>
            <a href="mailto:?subject=CV%20Ingeniero%20en%20Inform%C3%A1tica%20-%20Esteban%20Selvaggi&body=https%3A%2F%2Fselvaggiesteban.dev%2Fcv%2Fingeniero-en-informatica" class="p-2 bg-surface-soft border border-hairline rounded-full hover:bg-ink hover:text-white transition-colors text-ink" title="Compartir por Email">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </a>
            <a href="https://api.whatsapp.com/send?text=CV%20Ingeniero%20en%20Inform%C3%A1tica%20-%20Esteban%20Selvaggi:%20https%3A%2F%2Fselvaggiesteban.dev%2Fcv%2Fingeniero-en-informatica" target="_blank" class="p-2 bg-surface-soft border border-hairline rounded-full hover:bg-[#25D366] hover:text-white transition-colors text-ink" title="Compartir por WhatsApp">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"/><path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"/></svg>
            </a>
            <a href="https://t.me/share/url?url=https%3A%2F%2Fselvaggiesteban.dev%2Fcv%2Fingeniero-en-informatica&text=CV%20Ingeniero%20en%20Inform%C3%A1tica%20-%20Esteban%20Selvaggi" target="_blank" class="p-2 bg-surface-soft border border-hairline rounded-full hover:bg-[#0088cc] hover:text-white transition-colors text-ink" title="Compartir por Telegram">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M15 10l-4 4l6 6l4 -16l-18 7l4 2l2 6l3 -4"/></svg>
            </a>
          </div>

          <!-- Datos de contacto con texto -->
          <div class="text-sm text-ink/70 flex flex-col gap-2 md:items-end">
            <a href="mailto:selvaggiesteban@gmail.com" class="hover:text-primary transition-colors font-medium">
              <span class="text-ink/40 font-mono text-xs uppercase tracking-widest mr-1">E-mail:</span>selvaggiesteban@gmail.com
            </a>
            <a href="tel:+5491153323937" class="hover:text-primary transition-colors font-medium">
              <span class="text-ink/40 font-mono text-xs uppercase tracking-widest mr-1">Teléfono:</span>(+54) 9 11 5332-3937
            </a>
            <a href="https://linkedin.com/in/selvaggiesteban" target="_blank" class="hover:text-primary transition-colors font-medium">
              <span class="text-ink/40 font-mono text-xs uppercase tracking-widest mr-1">LinkedIn:</span>/selvaggiesteban
            </a>
            <a href="https://github.com/selvaggiesteban" target="_blank" class="hover:text-primary transition-colors font-medium">
              <span class="text-ink/40 font-mono text-xs uppercase tracking-widest mr-1">GitHub:</span>/selvaggiesteban
            </a>
          </div>
        </div>
      </div>

      <!-- Perfil -->
      <div class="mb-10">
        <h2 class="text-xl font-bold uppercase tracking-widest text-ink/40 mb-4 border-b border-hairline-soft pb-2">Perfil Profesional</h2>
        <div class="text-ink/80 space-y-4 leading-relaxed text-sm">
          <p>Ingeniero Informático con más de 8 años de trayectoria liderando el ciclo de vida completo del desarrollo de software e integraciones de sistemas. Especializado en arquitectura de sistemas de alto rendimiento, integración avanzada de Inteligencia Artificial (IA) y automatización robótica de procesos (RPA).</p>
          <p>Experto en transformar requisitos de negocio complejos en soluciones técnicas escalables, seguras y eficientes, con un enfoque riguroso en la calidad del código, la estabilidad de las bases de datos y la optimización de la infraestructura en la nube.</p>
        </div>
      </div>

      <!-- Experiencia -->
        <div class="mb-10">
          <h2 class="text-xl font-bold uppercase tracking-widest text-ink/40 mb-4 border-b border-hairline-soft pb-2">Experiencia Laboral</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-bold text-lg text-ink">Desarrollador Web Full-Stack - <a href="https://esloogan.com" target="_blank" class="hover:text-primary transition-colors">Esloogan</a></h3>
              <p class="text-sm text-ink/60 mt-1">Madrid, Comunidad de Madrid, España (En remoto) · ene. 2025 - <span class="inline-block bg-semantic-success/10 text-semantic-success text-xs font-medium px-2 py-0.5 rounded-full leading-none">actualidad</span></p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Encargado del diseño, mantenimiento y posicionamiento de sitios web.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Emprendedor - <a href="https://lanuscomputacion.com" target="_blank" class="hover:text-primary transition-colors">Lanús Computación</a></h3>
              <p class="text-sm text-ink/60 mt-1">Lanús, Provincia de Buenos Aires, Argentina (Presencial) · ene. 2014 - <span class="inline-block bg-semantic-success/10 text-semantic-success text-xs font-medium px-2 py-0.5 rounded-full leading-none">actualidad</span></p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Encargado del diseño, instalación y mantenimiento de sistemas informáticos.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Especialista en posicionamiento web - <a href="https://octonove.com/" target="_blank" class="hover:text-primary transition-colors">Octonove Agency</a></h3>
              <p class="text-sm text-ink/60 mt-1">Cartagena, Región de Murcia, España (En remoto) · sept. 2023 - abr. 2026</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Encargado del posicionamiento de sitios web.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Desarrollador Web Full-Stack - <a href="https://tvmasmagazine.com/" target="_blank" class="hover:text-primary transition-colors">TVMAS Magazine</a></h3>
              <p class="text-sm text-ink/60 mt-1">Miami 33129 (En remoto) · mar. 2022 - abr. 2026</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Encargado de campañas de e-mail marketing.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Personal docente - <a href="https://educacionit.com/" target="_blank" class="hover:text-primary transition-colors">EducacionIT</a></h3>
              <p class="text-sm text-ink/60 mt-1">Provincia de Buenos Aires, Argentina (En remoto) · ene. 2025 - oct. 2025</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Encargado de cursos de WordPress online.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Desarrollador Web Full-Stack - <a href="https://nice.com.ar" target="_blank" class="hover:text-primary transition-colors">Nice comunicación</a></h3>
              <p class="text-sm text-ink/60 mt-1">Provincia de Buenos Aires, Argentina (En remoto) · jul. 2023 - ene. 2025</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Encargado del diseño, mantenimiento y posicionamiento de sitios web.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Desarrollador Web Full-Stack - <a href="https://tepromocionamos.com/" target="_blank" class="hover:text-primary transition-colors">Te Promocionamos</a></h3>
              <p class="text-sm text-ink/60 mt-1">Provincia de Buenos Aires, Argentina (En remoto) · sept. 2023 - dic. 2024</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Encargado del diseño, mantenimiento y posicionamiento de sitios web.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Desarrollador Web Full-Stack - <a href="https://vestigiostudio.com/" target="_blank" class="hover:text-primary transition-colors">Vestigio Studio</a></h3>
              <p class="text-sm text-ink/60 mt-1">Provincia de Buenos Aires, Argentina · oct. 2023 - may. 2024</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Encargado del diseño, mantenimiento y posicionamiento de sitios web.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Desarrollador Web Full-Stack - <a href="https://www.estudiodmg.com.ar" target="_blank" class="hover:text-primary transition-colors">Estudio de Diseño DMG srl</a></h3>
              <p class="text-sm text-ink/60 mt-1">Lomas de Zamora, Provincia de Buenos Aires, Argentina (Presencial) · ene. 2023 - nov. 2023</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Encargado del diseño, mantenimiento y posicionamiento de sitios web.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Personal docente - <a href="https://www.linkedin.com/company/escuela-santa-teresa" target="_blank" class="hover:text-primary transition-colors">Escuela Santa Teresa</a></h3>
              <p class="text-sm text-ink/60 mt-1">Provincia de Buenos Aires, Argentina (Presencial) · feb. 2022 - feb. 2023</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Encargado de la gestión y evaluación de proyectos de incorporación tecnológica en educación inicial, primaria y secundaria.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Técnico mecánico - <a href="https://mako.com.ar/" target="_blank" class="hover:text-primary transition-colors">Mecanizados Mako</a></h3>
              <p class="text-sm text-ink/60 mt-1">Provincia de Buenos Aires, Argentina (Presencial) · may. 2017 - ene. 2021</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Encargado de la programación de centro CNC y procesos de mecanizado y fabricación de piezas mecánicas.</p>
            </div>
          </div>
        </div>

        <!-- Educación -->
      <div class="mb-10">
        <h2 class="text-xl font-bold uppercase tracking-widest text-ink/40 mb-4 border-b border-hairline-soft pb-2">Educación</h2>
        <div class="space-y-4">
          <div>
            <h3 class="font-bold text-lg text-ink">Grado en Ingeniería en Informática - Universidad de Buenos Aires</h3>
              <p class="text-sm text-ink/60 mt-1">Ago 2025 - Dic 2031</p>
          </div>
          <div>
            <h3 class="font-bold text-lg text-ink">Desarrollo Web Full Stack - Henry</h3>
              <p class="text-sm text-ink/60 mt-1">Ene 2023 - Dic 2025</p>
          </div>
          <div>
            <h3 class="font-bold text-lg text-ink">Operador avanzado de PC - Escuela Santa Teresa</h3>
              <p class="text-sm text-ink/60 mt-1">Mar 2012 - Dic 2018</p>
          </div>
          <div>
            <h3 class="font-bold text-lg text-ink">Bachiller en Economía y Gestión de las Organizaciones - Escuela Santa Teresa</h3>
              <p class="text-sm text-ink/60 mt-1">Mar 2012 - Dic 2018</p>
          </div>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>