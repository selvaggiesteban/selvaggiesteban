---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Button from '../../components/Button.astro';

const title = "CV Ingeniero de Software - Esteban Selvaggi";
const description = "Curriculum Vitae optimizado para ATS de Esteban Selvaggi, Ingeniero de Software experto en arquitecturas escalables y Clean Code.";
---

<BaseLayout {title} {description} isProfile={true}>
  <Section variant="white" class="pt-24 pb-16 reveal">
    <div class="w-full mx-auto">
      
      <!-- Header -->
      <div class="border-b border-hairline pb-8 mb-8 text-center md:text-left flex flex-col md:flex-row items-center md:items-start justify-between gap-6">
        <div>
          <h1 class="display-lg mb-2">Esteban Selvaggi</h1>
          <p class="text-2xl text-primary font-medium">Ingeniero de Software</p>
        </div>
        <div class="text-sm text-ink/70 flex flex-col gap-3 items-center sm:items-end flex-shrink-0">
          <span>📍 Provincia de Buenos Aires, Argentina</span>
          <a href="mailto:selvaggiesteban@gmail.com" class="hover:text-primary transition-colors">✉️ selvaggiesteban@gmail.com</a>
          <a href="tel:+5491153323937" class="hover:text-primary transition-colors">📱 (+54) 9 11 5332-3937</a>
          <a href="https://linkedin.com/in/selvaggiesteban" target="_blank" class="hover:text-primary transition-colors">💼 linkedin.com/in/selvaggiesteban</a>
