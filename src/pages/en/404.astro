---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import { t } from '../../i18n/utils';

const title = '404 — Page Not Found';
const description = 'The page you are looking for does not exist.';
---

<BaseLayout {title} {description}>
  <Section class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <h1 class="display-lg mb-4">404</h1>
      <p class="text-xl text-ink/60 mb-8">The page you are looking for does not exist or has been moved.</p>
      <a href="/en" class="inline-flex items-center gap-2 bg-primary text-white font-bold px-6 py-3 rounded-lg hover:bg-ink transition-colors">
        Back to Home
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </Section>
</BaseLayout>