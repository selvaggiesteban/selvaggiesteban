---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section from '../../../components/Section.astro';

const title = "Thank You!";
const description = "Thank you for getting in touch with us.";
---

<BaseLayout {title} {description} locale="en">
  <Section variant="lilac">
    <div class="text-center py-xl">
      <h1 class="display-lg mb-md">Message Sent!</h1>
      <p class="text-xl opacity-70 mb-xl">
        I have received your message and will get back to you shortly.
      </p>
      <a href="/en/" class="btn-primary">Back to Home</a>
    </div>
  </Section>
</BaseLayout>