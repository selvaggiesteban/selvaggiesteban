---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section from '../../../components/Section.astro';
import Button from '../../../components/Button.astro';

const title = "CV Full-Stack Web Developer - Esteban Selvaggi";
const description = "Esteban Selvaggi's ATS-optimized Curriculum Vitae, Professional Web Developer expert in UX/UI interfaces and responsive design.";
---

<BaseLayout {title} {description} isProfile={true}>
  <Section variant="white" class="pt-24 pb-16 reveal">
    <div class="w-full mx-auto">
      
      <!-- Header: 2 columns -->
      <div class="border-b border-hairline pb-8 mb-8 grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
        <!-- Left column: identity -->
        <div>
          <h1 class="display-lg mb-1">Esteban Selvaggi</h1>
          <p class="text-2xl text-primary font-medium">Full-Stack Web Developer</p>
        </div>

        <!-- Right column: share + contact -->
        <div class="flex flex-col gap-5 md:items-end">
          <!-- Share icons -->
          <div class="flex gap-2">
            <button onclick="navigator.clipboard.writeText(window.location.href); alert('Link copied to clipboard');" class="p-2 bg-surface-soft border border-hairline rounded-full hover:bg-ink hover:text-white transition-colors text-ink cursor-pointer" title="Copy Link">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            </button>
            <button onclick="window.print()" class="p-2 bg-surface-soft border border-hairline rounded-full hover:bg-ink hover:text-white transition-colors text-ink cursor-pointer" title="Print CV">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
            </button>
            <a href="mailto:?subject=CV%20Full-Stack%20Web%20Developer%20-%20Esteban%20Selvaggi&body=https%3A%2F%2Fselvaggiesteban.dev%2Fen%2Fcv%2Ffull-stack-web-developer" class="p-2 bg-surface-soft border border-hairline rounded-full hover:bg-ink hover:text-white transition-colors text-ink" title="Share by Email">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </a>
            <a href="https://api.whatsapp.com/send?text=CV%20Full-Stack%20Web%20Developer%20-%20Esteban%20Selvaggi:%20https%3A%2F%2Fselvaggiesteban.dev%2Fen%2Fcv%2Ffull-stack-web-developer" target="_blank" class="p-2 bg-surface-soft border border-hairline rounded-full hover:bg-[#25D366] hover:text-white transition-colors text-ink" title="Share by WhatsApp">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"/><path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"/></svg>
            </a>
            <a href="https://t.me/share/url?url=https%3A%2F%2Fselvaggiesteban.dev%2Fen%2Fcv%2Ffull-stack-web-developer&text=CV%20Full-Stack%20Web%20Developer%20-%20Esteban%20Selvaggi" target="_blank" class="p-2 bg-surface-soft border border-hairline rounded-full hover:bg-[#0088cc] hover:text-white transition-colors text-ink" title="Share by Telegram">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M15 10l-4 4l6 6l4 -16l-18 7l4 2l2 6l3 -4"/></svg>
            </a>
          </div>

          <!-- Contact data with text -->
          <div class="text-sm text-ink/70 flex flex-col gap-2 md:items-end">
            <a href="mailto:selvaggiesteban@gmail.com" class="hover:text-primary transition-colors font-medium">
              <span class="text-ink/40 font-mono text-xs uppercase tracking-widest mr-1">E-mail:</span>selvaggiesteban@gmail.com
            </a>
            <a href="tel:+5491153323937" class="hover:text-primary transition-colors font-medium">
              <span class="text-ink/40 font-mono text-xs uppercase tracking-widest mr-1">Phone:</span>(+54) 9 11 5332-3937
            </a>
            <a href="https://linkedin.com/in/selvaggiesteban" target="_blank" class="hover:text-primary transition-colors font-medium">
              <span class="text-ink/40 font-mono text-xs uppercase tracking-widest mr-1">LinkedIn:</span>/selvaggiesteban
            </a>
            <a href="https://github.com/selvaggiesteban" target="_blank" class="hover:text-primary transition-colors font-medium">
              <span class="text-ink/40 font-mono text-xs uppercase tracking-widest mr-1">GitHub:</span>/selvaggiesteban
            </a>
          </div>
        </div>
      </div>

      <!-- Profile -->
      <div class="mb-10">
        <h2 class="text-xl font-bold uppercase tracking-widest text-ink/40 mb-4 border-b border-hairline-soft pb-2">Professional Profile</h2>
        <div class="text-ink/80 space-y-4 leading-relaxed text-sm">
          <p>Senior Web Developer with 8+ years of experience creating intuitive digital interfaces. Specialist in responsive design (Mobile-First), corporate design systems, and UX/UI optimization focused on maximizing conversion rates.</p>
          <p>Expert in merging visual aesthetics with technical excellence, using cutting-edge tools such as Astro, React, and Tailwind CSS to deliver ultra-fast, accessible web products that communicate brand identities with perfection.</p>
        </div>
      </div>

      <!-- Experience -->
        <div class="mb-10">
          <h2 class="text-xl font-bold uppercase tracking-widest text-ink/40 mb-4 border-b border-hairline-soft pb-2">Work Experience</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-bold text-lg text-ink">Full-Stack Web Developer - <a href="https://esloogan.com" target="_blank" class="hover:text-primary transition-colors">Esloogan</a></h3>
              <p class="text-sm text-ink/60 mt-1">Madrid, Community of Madrid, Spain (Remote) · Jan 2025 - <span class="inline-block bg-semantic-success/10 text-semantic-success text-xs font-medium px-2 py-0.5 rounded-full leading-none">current</span></p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Responsible for design, maintenance, and positioning of websites.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Entrepreneur - <a href="https://lanuscomputacion.com" target="_blank" class="hover:text-primary transition-colors">Lanús Computación</a></h3>
              <p class="text-sm text-ink/60 mt-1">Lanús, Buenos Aires Province, Argentina (On-site) · Jan 2014 - <span class="inline-block bg-semantic-success/10 text-semantic-success text-xs font-medium px-2 py-0.5 rounded-full leading-none">current</span></p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Responsible for design, installation, and maintenance of computer systems.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Web Positioning Specialist - <a href="https://octonove.com/" target="_blank" class="hover:text-primary transition-colors">Octonove Agency</a></h3>
              <p class="text-sm text-ink/60 mt-1">Cartagena, Region of Murcia, Spain (Remote) · Sep 2023 - Apr 2026</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Responsible for website positioning.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Full-Stack Web Developer - <a href="https://tvmasmagazine.com/" target="_blank" class="hover:text-primary transition-colors">TVMAS Magazine</a></h3>
              <p class="text-sm text-ink/60 mt-1">Miami 33129 (Remote) · Mar 2022 - Apr 2026</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Responsible for email marketing campaigns.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Teaching Staff - <a href="https://educacionit.com/" target="_blank" class="hover:text-primary transition-colors">EducacionIT</a></h3>
              <p class="text-sm text-ink/60 mt-1">Buenos Aires Province, Argentina (Remote) · Jan 2025 - Oct 2025</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Responsible for online WordPress courses.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Full-Stack Web Developer - <a href="https://nice.com.ar" target="_blank" class="hover:text-primary transition-colors">Nice comunicación</a></h3>
              <p class="text-sm text-ink/60 mt-1">Buenos Aires Province, Argentina (Remote) · Jul 2023 - Jan 2025</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Responsible for design, maintenance, and positioning of websites.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Full-Stack Web Developer - <a href="https://tepromocionamos.com/" target="_blank" class="hover:text-primary transition-colors">Te Promocionamos</a></h3>
              <p class="text-sm text-ink/60 mt-1">Buenos Aires Province, Argentina (Remote) · Sep 2023 - Dec 2024</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Responsible for design, maintenance, and positioning of websites.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Full-Stack Web Developer - <a href="https://vestigiostudio.com/" target="_blank" class="hover:text-primary transition-colors">Vestigio Studio</a></h3>
              <p class="text-sm text-ink/60 mt-1">Buenos Aires Province, Argentina · Oct 2023 - May 2024</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Responsible for design, maintenance, and positioning of websites.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Full-Stack Web Developer - <a href="https://www.estudiodmg.com.ar" target="_blank" class="hover:text-primary transition-colors">Estudio de Diseño DMG srl</a></h3>
              <p class="text-sm text-ink/60 mt-1">Lomas de Zamora, Buenos Aires Province, Argentina (On-site) · Jan 2023 - Nov 2023</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Responsible for design, maintenance, and positioning of websites.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Teaching Staff - <a href="https://www.linkedin.com/company/escuela-santa-teresa" target="_blank" class="hover:text-primary transition-colors">Escuela Santa Teresa</a></h3>
              <p class="text-sm text-ink/60 mt-1">Buenos Aires Province, Argentina (On-site) · Feb 2022 - Feb 2023</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Responsible for management and evaluation of technology integration projects in early childhood, primary, and secondary education.</p>
            </div>
            <div>
              <h3 class="font-bold text-lg text-ink">Mechanical Technician - <a href="https://mako.com.ar/" target="_blank" class="hover:text-primary transition-colors">Mecanizados Mako</a></h3>
              <p class="text-sm text-ink/60 mt-1">Buenos Aires Province, Argentina (On-site) · May 2017 - Jan 2021</p>
              <p class="text-sm text-ink/80 mt-2 leading-relaxed">Responsible for CNC center programming and machining and manufacturing processes of mechanical parts.</p>
            </div>
          </div>
        </div>

        <!-- Education -->
      <div class="mb-10">
        <h2 class="text-xl font-bold uppercase tracking-widest text-ink/40 mb-4 border-b border-hairline-soft pb-2">Education</h2>
        <div class="space-y-4">
          <div>
            <h3 class="font-bold text-lg text-ink">Bachelor's Degree in Computer Science Engineering - Universidad de Buenos Aires</h3>
              <p class="text-sm text-ink/60 mt-1">Aug 2025 - Dec 2031</p>
          </div>
          <div>
            <h3 class="font-bold text-lg text-ink">Full Stack Web Development - Henry</h3>
              <p class="text-sm text-ink/60 mt-1">Jan 2023 - Dec 2025</p>
          </div>
          <div>
            <h3 class="font-bold text-lg text-ink">Advanced PC Operator - Escuela Santa Teresa</h3>
              <p class="text-sm text-ink/60 mt-1">Mar 2012 - Dec 2018</p>
          </div>
          <div>
            <h3 class="font-bold text-lg text-ink">High School Diploma in Economics and Organization Management - Escuela Santa Teresa</h3>
              <p class="text-sm text-ink/60 mt-1">Mar 2012 - Dec 2018</p>
          </div>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>
