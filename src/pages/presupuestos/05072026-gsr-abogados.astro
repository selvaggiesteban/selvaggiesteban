---
import PresupuestoLayout from '../../layouts/PresupuestoLayout.astro';
import { env } from 'cloudflare:workers';

// Datos Profesionales
const miRazonSocial = "SELVAGGI ESTEBAN";
const miDomicilio = "La Rioja 1935 - Villa Industriales, Buenos Aires";
const miCuit = "20433102593";
const fechaEmision = "14/07/2026";
const fechaVto = "29/07/2026";

// Datos del Cliente
const clienteNombre = "GSR Abogados";
const clienteEmpresa = "GSR Abogados";
const clienteCuit = "A COMPLETAR";
const clienteIva = "A COMPLETAR";
const clienteDomicilio = "A COMPLETAR";
const condicionVenta = "MercadoPago";

const proyecto = "Campaña Google Ads + Gestión Redes Sociales (LinkedIn e Instagram)";
const urlPresupuesto = "https://selvaggiesteban.dev/presupuestos/05072026-gsr-abogados";

let payLinkBasico = "#";
let payLinkPremium = "#";

const mpToken = env?.MP_ACCESS_TOKEN || process?.env?.MP_ACCESS_TOKEN;
if (mpToken) {
  try {
    const [resBasico, resPremium] = await Promise.all([
      fetch("https://api.mercadopago.com/checkout/preferences", {
        method: "POST",
        headers: {
          "Authorization": `Bearer ${mpToken}`,
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          items: [{
            title: "Google Ads + Redes Sociales Plan Básico - GSR Abogados",
            quantity: 1,
            unit_price: 947150,
            currency_id: "ARS"
          }],
          back_urls: {
            success: "https://selvaggiesteban.dev/presupuestos/05072026-gsr-abogados",
            failure: "https://selvaggiesteban.dev/presupuestos/05072026-gsr-abogados",
            pending: "https://selvaggiesteban.dev/presupuestos/05072026-gsr-abogados"
          },
          auto_return: "approved"
        })
      }),
      fetch("https://api.mercadopago.com/checkout/preferences", {
        method: "POST",
        headers: {
          "Authorization": `Bearer ${mpToken}`,
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          items: [{
            title: "Google Ads + Redes Sociales Plan Premium - GSR Abogados",
            quantity: 1,
            unit_price: 1306650,
            currency_id: "ARS"
          }],
          back_urls: {
            success: "https://selvaggiesteban.dev/presupuestos/05072026-gsr-abogados",
            failure: "https://selvaggiesteban.dev/presupuestos/05072026-gsr-abogados",
            pending: "https://selvaggiesteban.dev/presupuestos/05072026-gsr-abogados"
          },
          auto_return: "approved"
        })
      })
    ]);
    const [dataBasico, dataPremium] = await Promise.all([resBasico.json(), resPremium.json()]);
    payLinkBasico = dataBasico.init_point || "#";
    payLinkPremium = dataPremium.init_point || "#";
  } catch (error) {
    console.error("Error MercadoPago:", error);
  }
}
---


