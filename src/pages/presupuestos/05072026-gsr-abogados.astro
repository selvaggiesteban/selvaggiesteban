---
import PresupuestoLayout from '../../layouts/PresupuestoLayout.astro';
import { env } from 'cloudflare:workers';

// Datos Profesionales
const miRazonSocial = "SELVAGGI ESTEBAN";
const miDomicilio = "La Rioja 1935 - Villa Industriales, Buenos Aires";
const miCuit = "20433102593";
const fechaEmision = "14/07/2026";
const fechaVto = "29/07/2026";

// Datos del Cliente
const clienteNombre = "GSR Abogados";
const clienteEmpresa = "GSR Abogados";
const clienteCuit = "A COMPLETAR";
const clienteIva = "A COMPLETAR";
const clienteDomicilio = "A COMPLETAR";
const condicionVenta = "MercadoPago";

const proyecto = "Campaña Google Ads + Gestión Redes Sociales (LinkedIn e Instagram)";
const urlPresupuesto = "https://selvaggiesteban.dev/presupuestos/05072026-gsr-abogados";

let payLinkBasico = "#";
let payLinkPremium = "#";

const mpToken = env?.MP_ACCESS_TOKEN || process?.env?.MP_ACCESS_TOKEN;
if (mpToken) {
  try {
    const [resBasico, resPremium] = await Promise.all([
      fetch("https://api.mercadopago.com/checkout/preferences", {
        method: "POST",
        headers: {
          "Authorization": `Bearer ${mpToken}`,
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          items: [{
            title: "Google Ads + Redes Sociales Plan Básico - GSR Abogados",
            quantity: 1,
            unit_price: 947150,
            currency_id: "ARS"
          }],
          back_urls: {
            success: "https://selvaggiesteban.dev/presupuestos/05072026-gsr-abogados",
            failure: "https://selvaggiesteban.dev/presupuestos/05072026-gsr-abogados",
            pending: "https://selvaggiesteban.dev/presupuestos/05072026-gsr-abogados"
          },
          auto_return: "approved"
        })
      }),
      fetch("https://api.mercadopago.com/checkout/preferences", {
        method: "POST",
        headers: {
          "Authorization": `Bearer ${mpToken}`,
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          items: [{
            title: "Google Ads + Redes Sociales Plan Premium - GSR Abogados",
            quantity: 1,
            unit_price: 1306650,
            currency_id: "ARS"
          }],
          back_urls: {
            success: "https://selvaggiesteban.dev/presupuestos/05072026-gsr-abogados",
            failure: "https://selvaggiesteban.dev/presupuestos/05072026-gsr-abogados",
            pending: "https://selvaggiesteban.dev/presupuestos/05072026-gsr-abogados"
          },
          auto_return: "approved"
        })
      })
    ]);
    const [dataBasico, dataPremium] = await Promise.all([resBasico.json(), resPremium.json()]);
    payLinkBasico = dataBasico.init_point || "#";
    payLinkPremium = dataPremium.init_point || "#";
  } catch (error) {
    console.error("Error MercadoPago:", error);
  }
}
---


<PresupuestoLayout title={`Presupuesto: ${proyecto}`} description={`Propuesta comercial para ${clienteNombre}`}>

  <!-- Share Buttons -->
  <div class="flex justify-end gap-3 mb-6" style="margin-top: 50px;">
    <button onclick="navigator.clipboard.writeText(window.location.href); alert('Enlace copiado al portapapeles');" class="p-2 bg-surface-soft border border-hairline rounded-full hover:bg-ink hover:text-white transition-colors text-ink" title="Copiar Enlace">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
    </button>
    <button onclick="window.print()" class="p-2 bg-surface-soft border border-hairline rounded-full hover:bg-ink hover:text-white transition-colors text-ink hidden sm:inline-block" title="Imprimir Presupuesto">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
    </button>
    <a href={`mailto:?subject=Presupuesto%20Marketing%20Digital%20-%20SelvaggiEsteban.dev&body=Hola!%20Te%20comparto%20el%20link%20de%20la%20cotizaci%C3%B3n:%20${urlPresupuesto}`} class="p-2 bg-surface-soft border border-hairline rounded-full hover:bg-ink hover:text-white transition-colors text-ink" title="Compartir por Email">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
    </a>
    <a href={`https://api.whatsapp.com/send?text=Hola,%20aquí%20tienes%20el%20presupuesto%20de%20marketing%20digital:%20${urlPresupuesto}`} target="_blank" class="p-2 bg-surface-soft border border-hairline rounded-full hover:bg-[#25D366] hover:text-white transition-colors text-ink" title="Compartir por WhatsApp">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9" /><path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1" /></svg>
    </a>
  </div>

  <div class="mb-8">
    
    <!-- Encabezado de Facturación / Presupuesto -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 border-b border-hairline-soft pb-8">
      <div>
        <h1 class="text-3xl font-bold text-ink mb-6">Presupuesto</h1>
        <div class="text-sm text-ink/80 space-y-1">
          <p><span class="font-bold">Razón Social:</span> {miRazonSocial}</p>
          <p><span class="font-bold">CUIT:</span> {miCuit}</p>
          <p><span class="font-bold">Domicilio Comercial:</span> {miDomicilio}</p>
        </div>
      </div>
      <div class="md:text-right text-sm text-ink/80 space-y-1 bg-surface-soft p-5 rounded-[9px] border border-hairline">
        <p><span class="font-bold">Fecha de emisión:</span> {fechaEmision}</p>
        <p><span class="font-bold text-primary">Válido hasta:</span> {fechaVto}</p>
        <div class="my-4 border-t border-hairline-soft"></div>
        <p><span class="font-bold">Apellido y nombre / Razón social:</span> {clienteNombre} ({clienteEmpresa})</p>
        <p><span class="font-bold">CUIT:</span> {clienteCuit === "A COMPLETAR" ? <span class="text-red-500 font-normal">A COMPLETAR</span> : clienteCuit}</p>
        <p><span class="font-bold">Condición IVA:</span> {clienteIva === "A COMPLETAR" ? <span class="text-red-500 font-normal">A COMPLETAR</span> : clienteIva}</p>
        <p><span class="font-bold">Domicilio:</span> {clienteDomicilio === "A COMPLETAR" ? <span class="text-red-500 font-normal">A COMPLETAR</span> : clienteDomicilio}</p>
        <p><span class="font-bold">Condición de Venta:</span> {condicionVenta}</p>
      </div>
    </div>

    <!-- SECCIÓN 1: GOOGLE ADS -->
    <div class="mb-10">
      <h2 class="text-xl font-bold mb-6 text-ink">
        1. Campaña Google Ads
      </h2>
      <div class="overflow-x-auto mb-4 border border-hairline rounded-[9px]">
        <table class="w-full text-left text-sm whitespace-nowrap">
          <thead class="bg-surface-soft border-b border-hairline text-ink/70 uppercase text-xs tracking-wider">
            <tr>
              <th class="p-4 font-bold">Código</th>
              <th class="p-4 font-bold">Producto / Servicio</th>
              <th class="p-4 font-bold text-right">Cantidad</th>
              <th class="p-4 font-bold text-center">U. Medida</th>
              <th class="p-4 font-bold text-right">Precio Unit.</th>
              <th class="p-4 font-bold text-right">Subtotal</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-hairline">
            <tr class="hover:bg-surface-soft/50 transition-colors">
              <td class="p-4 font-mono text-xs text-ink/60">ADS-01</td>
              <td class="p-4 font-bold text-ink whitespace-normal min-w-[200px]">Alta Campaña Google Ads<br/><em class="text-xs text-ink/60">*Setup inicial + Research keywords legales + Configuración campañas</em></td>
              <td class="p-4 text-right">1.00</td>
              <td class="p-4 text-center">unidades</td>
              <td class="p-4 text-right">$85.000,00</td>
              <td class="p-4 text-right font-bold">$85.000,00</td>
            </tr>
            <tr class="hover:bg-surface-soft/50 transition-colors">
              <td class="p-4 font-mono text-xs text-ink/60">ADS-02</td>
              <td class="p-4 whitespace-normal min-w-[200px]">Gestión Mensual Campaña Google Ads<br/><em class="text-xs text-ink/60">*Optimización, reportes y ajustes (6 meses)</em></td>
              <td class="p-4 text-right">6.00</td>
              <td class="p-4 text-center">meses</td>
              <td class="p-4 text-right">$50.000,00</td>
              <td class="p-4 text-right font-bold">$300.000,00</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="bg-surface-soft rounded-[9px] p-4 border border-hairline flex justify-between items-center">
        <span class="font-bold text-ink">Subtotal Google Ads (6 meses):</span>
        <span class="text-lg font-bold text-primary">$385.000,00</span>
      </div>
    </div>

    <!-- SECCIÓN 2: REDES SOCIALES -->
    <div class="mb-10">
      <h2 class="text-xl font-bold mb-6 text-ink">
        2. Gestión Redes Sociales (LinkedIn + Instagram)
      </h2>

      <div class="overflow-x-auto mb-4 border border-hairline rounded-[9px]">
        <table class="w-full text-left text-sm whitespace-nowrap">
          <thead class="bg-surface-soft border-b border-hairline text-ink/70 uppercase text-xs tracking-wider">
            <tr>
              <th class="p-4 font-bold">Código</th>
              <th class="p-4 font-bold">Producto / Servicio</th>
              <th class="p-4 font-bold text-right">Cantidad</th>
              <th class="p-4 font-bold text-center">U. Medida</th>
              <th class="p-4 font-bold text-right">Precio Unit.</th>
              <th class="p-4 font-bold text-right">Subtotal</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-hairline">
            <tr class="hover:bg-surface-soft/50 transition-colors">
              <td class="p-4 font-mono text-xs text-ink/60">RED-01</td>
              <td class="p-4 font-bold text-ink whitespace-normal min-w-[200px]">Plan Básico - Gestión Redes Sociales<br/><em class="text-xs text-ink/60">*3 publicaciones/semana, imágenes, carruseles, copywriting, gestión de comunidad (3 meses)</em></td>
              <td class="p-4 text-right">3.00</td>
              <td class="p-4 text-center">meses</td>
              <td class="p-4 text-right">$204.000,00</td>
              <td class="p-4 text-right font-bold">$612.000,00</td>
            </tr>
            <tr class="hover:bg-surface-soft/50 transition-colors">
              <td class="p-4 font-mono text-xs text-ink/60">RED-02</td>
              <td class="p-4 whitespace-normal min-w-[200px]">Plan Premium - Gestión Redes Sociales<br/><em class="text-xs text-ink/60">*5 publicaciones/semana, reels, stories, SEO social, estrategia B2B jurídica (3 meses)</em></td>
              <td class="p-4 text-right">3.00</td>
              <td class="p-4 text-center">meses</td>
              <td class="p-4 text-right">$340.000,00</td>
              <td class="p-4 text-right font-bold">$1.020.000,00</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="bg-surface-soft rounded-[9px] p-4 border border-hairline flex justify-between items-center">
        <span class="font-bold text-ink">Elegí el plan que mejor se adapte a tus necesidades.</span>
      </div>
    </div>

    <!-- SECCIÓN 3: SERVICIO TÉCNICO DE PC -->
    <div class="mb-10">
      <h2 class="text-xl font-bold mb-6 text-ink">
        3. Servicio técnico de PC
      </h2>

      <div class="overflow-x-auto mb-4 border border-hairline rounded-[9px]">
        <table class="w-full text-left text-sm whitespace-nowrap">
          <thead class="bg-surface-soft border-b border-hairline text-ink/70 uppercase text-xs tracking-wider">
            <tr>
              <th class="p-4 font-bold">Código</th>
              <th class="p-4 font-bold">Producto / Servicio</th>
              <th class="p-4 font-bold text-right">Cantidad</th>
              <th class="p-4 font-bold text-center">U. Medida</th>
              <th class="p-4 font-bold text-right">Precio Unit.</th>
              <th class="p-4 font-bold text-right">Subtotal</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-hairline">
            <tr class="hover:bg-surface-soft/50 transition-colors">
              <td class="p-4 font-mono text-xs text-ink/60">PC-01</td>
              <td class="p-4 font-bold text-ink whitespace-normal min-w-[200px]">Router TP-Link Gigabit Ex141 Wi-Fi 6<br/><em class="text-xs text-ink/60">*Doble banda Ax1500</em></td>
              <td class="p-4 text-right">1.00</td>
              <td class="p-4 text-center">unidad</td>
              <td class="p-4 text-right">$75.999,00</td>
              <td class="p-4 text-right font-bold">$75.999,00</td>
            </tr>
            <tr class="hover:bg-surface-soft/50 transition-colors">
              <td class="p-4 font-mono text-xs text-ink/60">PC-02</td>
              <td class="p-4 font-bold text-ink whitespace-normal min-w-[200px]">Monitor Gamer AsRock Challenger CL27FFA<br/><em class="text-xs text-ink/60">*27" IPS FHD 120Hz Flicker Free Technology</em></td>
              <td class="p-4 text-right">1.00</td>
              <td class="p-4 text-center">unidad</td>
              <td class="p-4 text-right">$220.000,00</td>
              <td class="p-4 text-right font-bold">$220.000,00</td>
            </tr>
            <tr class="hover:bg-surface-soft/50 transition-colors">
              <td class="p-4 font-mono text-xs text-ink/60">PC-03</td>
              <td class="p-4 text-ink whitespace-normal min-w-[200px]">Instalación de antivirus</td>
              <td class="p-4 text-right">2.00</td>
              <td class="p-4 text-center">unidad</td>
              <td class="p-4 text-right">$34.000,00</td>
              <td class="p-4 text-right font-bold">$68.000,00</td>
            </tr>
            <tr class="hover:bg-surface-soft/50 transition-colors">
              <td class="p-4 font-mono text-xs text-ink/60">PC-04</td>
              <td class="p-4 text-ink whitespace-normal min-w-[200px]">Configuración de red Wi-Fi</td>
              <td class="p-4 text-right">1.00</td>
              <td class="p-4 text-center">servicio</td>
              <td class="p-4 text-right">$51.000,00</td>
              <td class="p-4 text-right font-bold">$51.000,00</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="bg-surface-soft rounded-[9px] p-4 border border-hairline flex justify-between items-center">
        <span class="font-bold text-ink">Subtotal Servicio Técnico:</span>
        <span class="text-lg font-bold text-primary">$414.999,00</span>
      </div>
    </div>

    <!-- Cierre y Pago -->
    <div class="text-center pt-8 border-t border-hairline-soft">
      <h3 class="text-lg font-bold mb-4">¿Listo para impulsar tu presencia digital?</h3>
      <p class="text-ink/60 mb-6 text-sm mx-auto">Al realizar el pago confirmas la aceptación del presupuesto y comenzamos con la configuración de las campañas en un plazo de 48 horas hábiles. Elegí la opción que mejor se adapte a tus necesidades.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={payLinkBasico} target="_blank" class="inline-flex items-center justify-center gap-3 bg-[#009EE3] hover:bg-[#0088cc] text-white rounded-[9px] px-8 py-4 font-semibold text-lg transition-colors shadow-md">
          <img src="/assets/mp/mercadopago.svg" alt="Mercado Pago" class="h-6 object-contain" />
          Pagar Plan Básico - $947.150
        </a>
        <a href={payLinkPremium} target="_blank" class="inline-flex items-center justify-center gap-3 bg-primary hover:bg-primary/80 text-white rounded-[9px] px-8 py-4 font-semibold text-lg transition-colors shadow-md">
          <img src="/assets/mp/mercadopago.svg" alt="Mercado Pago" class="h-6 object-contain" />
          Pagar Plan Premium - $1.306.650
        </a>
      </div>
      <div class="mt-6 flex flex-wrap justify-center items-center gap-3 opacity-90">
        <span class="flex items-center justify-center h-8 max-w-[100px] min-w-[64px] px-2"><img src="/assets/mp/visa.svg" alt="Visa" class="h-8 w-auto object-contain" title="Visa" /></span>
        <span class="flex items-center justify-center h-8 max-w-[100px] min-w-[64px] px-2"><img src="/assets/mp/mastercard.svg" alt="Mastercard" class="h-8 w-auto object-contain" title="Mastercard" /></span>
        <span class="flex items-center justify-center h-8 max-w-[100px] min-w-[64px] px-2"><img src="/assets/mp/amex.svg" alt="American Express" class="h-8 w-auto object-contain" title="American Express" /></span>
      </div>
    </div>
  </div>

</PresupuestoLayout>
