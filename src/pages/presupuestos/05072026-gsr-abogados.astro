            </tr>
          </tbody>
        </table>
      </div>

      <!-- OPCIÓN BÁSICA -->
      <div class="bg-surface-soft rounded-[9px] p-6 border border-hairline mb-4">
        <h3 class="font-bold text-ink mb-3">Opción A: Plan Básico (3 posts/semana)</h3>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between items-center text-ink/80">
            <span>Google Ads (Alta + 6 meses gestión):</span>
            <span class="font-medium">$385.000</span>
          </div>
