---
import PresupuestoLayout from '../../layouts/PresupuestoLayout.astro';
import { env } from 'cloudflare:workers';

// Datos Profesionales
const miRazonSocial = "SELVAGGI ESTEBAN";
const miDomicilio = "La Rioja 1935 - Villa Industriales, Buenos Aires";
const miCuit = "20433102593";
const fechaEmision = "12/07/2026";
const fechaVto = "26/07/2026";

// Datos del Cliente
const clienteNombre = "Matías Garcete";
const clienteEmpresa = "Suarez Ronco Abogados";
const clienteCuit = "A COMPLETAR";
const clienteIva = "A COMPLETAR";
const clienteDomicilio = "A COMPLETAR";
const condicionVenta = "MercadoPago";

const proyecto = "Campaña Google Ads + Pauta Instagram y LinkedIn + Equipamiento PC (Repetidor, Monitor y Antivirus)";
const urlPresupuesto = "https://selvaggiesteban.dev/presupuestos/12072026-garcete-suarez-ronco";

let payLinkBasico = "#";
let payLinkPremium = "#";

const mpToken = env?.MP_ACCESS_TOKEN || process?.env?.MP_ACCESS_TOKEN;
if (mpToken) {
  try {
    const [resBasico, resPremium] = await Promise.all([
      fetch("https://api.mercadopago.com/checkout/preferences", {
        method: "POST",
        headers: {
          "Authorization": `Bearer ${mpToken}`,
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          items: [{
            title: "Google Ads + Pauta Redes + Equipamiento PC Plan Básico - Suarez Ronco Abogados",
            quantity: 1,
            unit_price: 641250,
            currency_id: "ARS"
          }],
          back_urls: {
            success: "https://selvaggiesteban.dev/presupuestos/12072026-garcete-suarez-ronco",
            failure: "https://selvaggiesteban.dev/presupuestos/12072026-garcete-suarez-ronco",
            pending: "https://selvaggiesteban.dev/presupuestos/12072026-garcete-suarez-ronco"
          },
          auto_return: "approved"
        })
      }),
      fetch("https://api.mercadopago.com/checkout/preferences", {
        method: "POST",
        headers: {
          "Authorization": `Bearer ${mpToken}`,
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          items: [{
            title: "Google Ads + Pauta Redes + Equipamiento PC Plan Premium - Suarez Ronco Abogados",
            quantity: 1,
            unit_price: 823050,
            currency_id: "ARS"
          }],
          back_urls: {
            success: "https://selvaggiesteban.dev/presupuestos/12072026-garcete-suarez-ronco",
            failure: "https://selvaggiesteban.dev/presupuestos/12072026-garcete-suarez-ronco",
            pending: "https://selvaggiesteban.dev/presupuestos/12072026-garcete-suarez-ronco"
          },
          auto_return: "approved"
        })
      })
    ]);
    const [dataBasico, dataPremium] = await Promise.all([resBasico.json(), resPremium.json()]);
    payLinkBasico = dataBasico.init_point || "#";
    payLinkPremium = dataPremium.init_point || "#";
  } catch (error) {
    console.error("Error MercadoPago:", error);
  }
}
