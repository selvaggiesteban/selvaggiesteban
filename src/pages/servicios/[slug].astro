---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';

export const prerender = true;\nexport async function getStaticPaths() {
  const servicios = await getCollection('servicios');
  return servicios.map(servicio => ({
    params: { slug: servicio.id },
    props: { servicio },
  }));
}

const { servicio } = Astro.props;
import { render } from 'astro:content';
const { Content } = await render(servicio);
---

<BaseLayout isService={true} title={servicio.data.title} description={servicio.data.description}>
  <Section>
    <div class="max-w-3xl mx-auto">
      <h1 class="display-lg mb-md">{servicio.data.title}</h1>
      <p class="text-xl text-ink/60 mb-xl italic">{servicio.data.description}</p>
      <div class="prose prose-ink max-w-none">
        <Content />
      </div>
    </div>
  </Section>
</BaseLayout>
